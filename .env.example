# ─────────────────────────────────────────────────────────────────────────────
# Gurt — Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach `.env.local` und trage echte Werte ein.
# `.env.local` ist in .gitignore — committe NIEMALS echte Keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sanity (Content-Schicht) ────────────────────────────────────────────────
# Anlegen unter https://www.sanity.io/manage → Projekt erstellen.
# projectId & dataset findest du im Projekt-Dashboard.
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"

# Read-Token (Rolle: Viewer) für Draft-/Preview-Fetches im Visual Editing.
# Sanity Manage → API → Tokens → Add API token (Viewer).
SANITY_API_READ_TOKEN="your-viewer-token"

# Frei wählbares Geheimnis, das Studio & Frontend für Draft-Mode teilen.
SANITY_PREVIEW_SECRET="change-me-to-a-long-random-string"

# Studio liest eigene (SANITY_STUDIO_*-)Variablen. Auf dieselben Werte setzen.
SANITY_STUDIO_PROJECT_ID="your-project-id"
SANITY_STUDIO_DATASET="production"
SANITY_STUDIO_PREVIEW_URL="http://localhost:3000"

# Optionale Browser-Token (Viewer) für Echtzeit-SSE im Visual Editing.
# NEXT_PUBLIC_SANITY_BROWSER_TOKEN="your-viewer-token"

# ── Bundestag DIP API (Daten-Schicht) ───────────────────────────────────────
# Eigenen Key per E-Mail anfordern: parlamentsdokumentation@bundestag.de
# Hinweis: Die früher öffentlich dokumentierten Test-Keys sind inzwischen
# deaktiviert (HTTP 401) — ein eigener Key ist erforderlich.
DIP_API_KEY="your-dip-api-key"

# ── Destatis GENESIS-Online API (Daten-Schicht) ─────────────────────────────
# Amtliche Statistik (Statistisches Bundesamt). Kostenloses Konto anlegen unter
# https://www-genesis.destatis.de → einloggen → „Webservice (API)" → Token erzeugen.
# Der Token wird im HTTP-Header `username` übergeben (Passwort bleibt leer).
# Datenlizenz: dl-de/by-2-0 (Namensnennung). Siehe docs/04-data-sources.md.
GENESIS_API_TOKEN="your-genesis-api-token"

# ── Frontend ────────────────────────────────────────────────────────────────
# Lokal: http://localhost:3000 · Produktion (Vercel-Env setzen): https://gurt.info
# Steuert metadataBase (Canonical-URL, OpenGraph-/Share-Bilder).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Postfach für Leser-Hinweise & Korrekturen (mailto-Link je Beitrag).
# MUSS ein echtes, erreichbares Postfach sein. Fallback im Code: hinweise@gurt.info
NEXT_PUBLIC_CORRECTIONS_EMAIL="hinweise@gurt.info"
