# Studio-Umgebung — kopiere nach `apps/studio/.env.local` und trage Werte ein.
#
# WICHTIG: Die Sanity-CLI und das Studio (`sanity dev`/`build`/`deploy`) laden
# `SANITY_STUDIO_*`-Variablen aus DIESEM Verzeichnis (apps/studio/) — NICHT aus
# der Repo-Root-`.env.local` (die das Next.js-Frontend versorgt).
SANITY_STUDIO_PROJECT_ID="your-project-id"
SANITY_STUDIO_DATASET="production"
SANITY_STUDIO_PREVIEW_URL="http://localhost:3000"
